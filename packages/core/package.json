{
  "name": "@pre-markdown/core",
  "version": "0.1.0",
  "description": "Core AST types, builders, visitors, and event system for PreMarkdown",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist"
  },
  "files": ["dist"],
  "keywords": ["markdown", "ast", "parser", "pretext"]
}
