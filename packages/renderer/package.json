{
  "name": "@pre-markdown/renderer",
  "version": "0.2.0",
  "description": "High-performance AST to HTML renderer for PreMarkdown",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "license": "MIT",
  "author": "tickli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Leo555/pre-markdown.git",
    "directory": "packages/renderer"
  },
  "homepage": "https://github.com/Leo555/pre-markdown/tree/master/packages/renderer#readme",
  "bugs": {
    "url": "https://github.com/Leo555/pre-markdown/issues"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@pre-markdown/core": "workspace:*"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "markdown",
    "renderer",
    "html",
    "pretext"
  ]
}
